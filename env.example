# ──────────────────────────────────────────────────────────────
# PRO P2P Terminal — Backup Bot env vars
# Copy to .env on Render and fill in real values
# ──────────────────────────────────────────────────────────────

# Telegram Bot Token (from @BotFather)
TG_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID (your personal / group chat — get from @userinfobot)
TG_CHAT=your_telegram_chat_id_here

# Firebase Realtime Database URL
FIREBASE_DB_URL=https://your-project-default-rtdb.firebaseio.com

# Firebase Service Account JSON (paste the ENTIRE downloaded JSON on ONE line, minified)
# Example: {"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Your Render.com deployment URL (used for 10-min self-ping to prevent spin-down)
RENDER_EXTERNAL_URL=https://your-app-name.onrender.com

# Port (Render injects this automatically — leave blank for local dev)
PORT=10000
